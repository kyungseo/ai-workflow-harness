{
  "system_prompt": "./system.md",

  "model": "claude-3-5-sonnet-latest",
  "max_tokens": 8000,
  "temperature": 0.2,

  "tools": {
    "bash": true,
    "read": true,
    "write": true
  },

  "constraints": {
    "no_destructive_commands": true,
    "no_sudo": true,
    "no_network_calls": false
  }
}