#!/usr/bin/env sh
# Validates commit message format: Conventional Commits
# https://www.conventionalcommits.org
#
# Valid types: feat fix docs style refactor chore config test perf ci build revert
# Format: type(optional-scope): subject

TYPES="feat|fix|docs|style|refactor|chore|config|test|perf|ci|build|revert"
MSG_FILE=$1
MSG=$(cat "$MSG_FILE")

if ! echo "$MSG" | grep -qE "^($TYPES)(\(.+\))?: .+"; then
    echo ""
    echo "  ERROR: Invalid commit message format."
    echo ""
    echo "  Expected : type(scope?): subject"
    echo "  Example  : docs(workflow): update approval matrix"
    echo "  Types    : feat fix docs style refactor chore config test perf ci build revert"
    echo ""
    exit 1
fi

is_source_gitflow() {
    grep -q "policy_type: source-gitflow" docs/GIT-WORKFLOW.md 2>/dev/null
}

is_finalization_file() {
    case "$1" in
        docs/STATUS.md|docs/backlog/*|docs/works/*|docs/decisions/README.md)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

has_gate_override() {
    echo "$MSG" | grep -qE '^AWH-Gate-Override:[[:space:]]*finalization-split[[:space:]]*$'
}

has_any_gate_override() {
    echo "$MSG" | grep -qE '^AWH-Gate-Override:'
}

has_gate_reason() {
    echo "$MSG" | grep -qE '^AWH-Gate-Reason:[[:space:]]*[^[:space:]].*'
}

git_path_exists() {
    [ -f "$(git rev-parse --git-path "$1" 2>/dev/null)" ]
}

remote_count() {
    git remote 2>/dev/null | wc -l | tr -d ' '
}

remote_refs_containing_head() {
    git branch -r --contains HEAD 2>/dev/null | sed 's/^[* ]*//'
}

has_upstream() {
    git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1
}

classify_finalization_context() {
    if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
        echo "n/a-initial"
        return
    fi

    BRANCH=$(git branch --show-current 2>/dev/null || echo "")
    if [ -z "$BRANCH" ]; then
        echo "warning-detached-head"
        return
    fi

    if git_path_exists MERGE_HEAD || git_path_exists REBASE_HEAD || \
       git_path_exists CHERRY_PICK_HEAD || git_path_exists REVERT_HEAD || \
       [ -d "$(git rev-parse --git-path rebase-merge 2>/dev/null)" ] || \
       [ -d "$(git rev-parse --git-path rebase-apply 2>/dev/null)" ]; then
        echo "warning-sequencer"
        return
    fi

    if [ "$(remote_count)" -eq 0 ]; then
        echo "warning-no-remote"
        return
    fi

    REMOTE_CONTAINS=$(remote_refs_containing_head)
    if [ -n "$REMOTE_CONTAINS" ]; then
        echo "report-only-published"
        return
    fi

    if has_upstream; then
        echo "warning-upstream-exists-head-unpushed"
        return
    fi

    echo "hard-stop-local-only"
}

if is_source_gitflow; then
    if has_any_gate_override && ! has_gate_override; then
        echo ""
        echo "  ERROR: Invalid AWH gate override trailer."
        echo ""
        echo "  Expected : AWH-Gate-Override: finalization-split"
        echo ""
        exit 1
    fi
    if has_gate_override && ! has_gate_reason; then
        echo ""
        echo "  ERROR: AWH gate override requires a durable reason."
        echo ""
        echo "  Add      : AWH-Gate-Reason: <one-line reason>"
        echo ""
        exit 1
    fi

    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
    FINALIZATION_COUNT=0
    SUBSTANTIVE_COUNT=0
    for FILE in $STAGED_FILES; do
        if is_finalization_file "$FILE"; then
            FINALIZATION_COUNT=$((FINALIZATION_COUNT + 1))
        else
            SUBSTANTIVE_COUNT=$((SUBSTANTIVE_COUNT + 1))
        fi
    done

    if [ "$FINALIZATION_COUNT" -gt 0 ] && [ "$SUBSTANTIVE_COUNT" -eq 0 ]; then
        CONTEXT=$(classify_finalization_context)
        case "$CONTEXT" in
            hard-stop-local-only)
                if has_gate_override; then
                    echo "AWH finalization gate override recorded: finalization-split"
                else
                    echo ""
                    echo "  ERROR: Finalization-only commit blocked by DR-025."
                    echo ""
                    echo "  This branch appears provably local-only, so T15/T16 finalization"
                    echo "  should be bundled with the substantive work commit, usually via amend."
                    echo ""
                    echo "  If splitting is intentional, add both commit trailers:"
                    echo "    AWH-Gate-Override: finalization-split"
                    echo "    AWH-Gate-Reason: <one-line reason>"
                    echo ""
                    exit 1
                fi
                ;;
            warning-*|n/a-*)
                echo "WARNING: Finalization-only commit allowed; local-only hard-stop was not provable ($CONTEXT)."
                ;;
            report-only-*)
                echo "INFO: Finalization-only commit allowed in published/shared context ($CONTEXT)."
                ;;
        esac
    fi
fi
