#!/usr/bin/env sh
# Runs lightweight repository checks before commit.

set -eu

echo "Running diff hygiene check..."
git diff --cached --check

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

is_source_gitflow() {
    grep -q "policy_type: source-gitflow" docs/GIT-WORKFLOW.md 2>/dev/null
}

is_finalization_file() {
    case "$1" in
        docs/STATUS.md|docs/backlog/*|docs/works/*|docs/decisions/README.md)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

FINALIZATION_ONLY=0
if is_source_gitflow; then
    FINALIZATION_COUNT=0
    SUBSTANTIVE_COUNT=0
    for FILE in $STAGED_FILES; do
        if is_finalization_file "$FILE"; then
            FINALIZATION_COUNT=$((FINALIZATION_COUNT + 1))
        else
            SUBSTANTIVE_COUNT=$((SUBSTANTIVE_COUNT + 1))
        fi
    done
    if [ "$FINALIZATION_COUNT" -gt 0 ] && [ "$SUBSTANTIVE_COUNT" -eq 0 ]; then
        FINALIZATION_ONLY=1
    fi
fi

BRANCH=$(git branch --show-current 2>/dev/null || echo "")
# initial commit, merge commit (release sync 등) — branch isolation check 면제
if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    : # skip — initial commit, no HEAD yet
elif [ -f ".git/MERGE_HEAD" ]; then
    : # skip — merge commit
elif [ "$BRANCH" = "develop" ] || [ "$BRANCH" = "main" ]; then
    PROTECTED=""
    for FILE in $STAGED_FILES; do
        case "$FILE" in
            AGENTS.md|CLAUDE.md|docs/STATUS.md|\
            docs/backlog/*|docs/works/*|docs/decisions/*|\
            docs/AGENT-WORKFLOW.md|docs/HARNESS-PROTOCOL.md|\
            docs/HARNESS-QUICK-REFERENCE.md|docs/GIT-WORKFLOW.md|\
            .claude/commands/*|.claude/rules/*|.cursor/rules/*|\
            .agents/skills/*|prompts/*|scripts/create-harness.sh|\
            tools/git-hooks/*)
                PROTECTED="$PROTECTED $FILE"
                ;;
        esac
    done
    if [ -n "$PROTECTED" ]; then
        if [ "$BRANCH" = "main" ]; then
            echo "ERROR: Committing protected workflow files directly on 'main' is not allowed."
            echo "Create a feature/* or hotfix/* branch and commit there instead."
            echo "Affected files:"
            for F in $PROTECTED; do echo "  $F"; done
            exit 1
        else
            echo "WARNING: Committing protected workflow files directly on 'develop'."
            echo "Consider using a feature/* or hotfix/* branch instead."
            echo "Affected files:"
            for F in $PROTECTED; do echo "  $F"; done
        fi
    fi
fi

for FILE in $STAGED_FILES; do
    case "$FILE" in
        scripts/*.sh|scripts/*/*.sh|tools/git-hooks/*)
            if [ -f "$FILE" ]; then
                echo "Checking shell syntax: $FILE"
                sh -n "$FILE"
            fi
            ;;
    esac
done

if echo "$STAGED_FILES" | grep -q '^scripts/create-harness\.sh$'; then
    echo "Checking create-harness.sh syntax..."
    bash -n scripts/create-harness.sh
fi

if [ "$FINALIZATION_ONLY" -eq 1 ]; then
    echo "WARNING: Staged changes look like a finalization-only commit."
    echo "DR-025 prefers bundling T15/T16 finalization with the substantive work commit."
    echo "The commit-msg hook will decide hard-stop/warning/report-only using git context and override trailers."
    echo "Override trailer when intentional:"
    echo "  AWH-Gate-Override: finalization-split"
    echo "  AWH-Gate-Reason: <one-line reason>"
fi

echo "Pre-commit checks passed."
