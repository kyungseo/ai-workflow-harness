#!/usr/bin/env sh
# Runs lightweight repository checks before commit.

set -eu

echo "Running diff hygiene check..."
git diff --cached --check

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

BRANCH=$(git branch --show-current 2>/dev/null || echo "")
# merge commit (release sync 등) — branch isolation check 면제
if [ -f ".git/MERGE_HEAD" ]; then
    : # skip
elif [ "$BRANCH" = "develop" ] || [ "$BRANCH" = "main" ]; then
    PROTECTED=""
    for FILE in $STAGED_FILES; do
        case "$FILE" in
            AGENTS.md|CLAUDE.md|docs/STATUS.md|\
            docs/backlog/*|docs/works/*|docs/decisions/*|\
            docs/AGENT-WORKFLOW.md|docs/HARNESS-PROTOCOL.md|\
            docs/HARNESS-QUICK-REFERENCE.md|docs/GIT-WORKFLOW.md|\
            .claude/commands/*|.claude/rules/*|.cursor/rules/*|\
            .agents/skills/*|prompts/*|scripts/create-harness.sh|\
            tools/git-hooks/*)
                PROTECTED="$PROTECTED $FILE"
                ;;
        esac
    done
    if [ -n "$PROTECTED" ]; then
        echo "ERROR: Committing protected workflow files directly on '$BRANCH' is not allowed."
        echo "Create a feature/* or hotfix/* branch and commit there instead."
        echo "Affected files:"
        for F in $PROTECTED; do echo "  $F"; done
        exit 1
    fi
fi

for FILE in $STAGED_FILES; do
    case "$FILE" in
        scripts/*.sh|scripts/*/*.sh|tools/git-hooks/*)
            if [ -f "$FILE" ]; then
                echo "Checking shell syntax: $FILE"
                sh -n "$FILE"
            fi
            ;;
    esac
done

if echo "$STAGED_FILES" | grep -q '^scripts/create-harness\.sh$'; then
    echo "Checking create-harness.sh syntax..."
    bash -n scripts/create-harness.sh
fi

echo "Pre-commit checks passed."
