#!/usr/bin/env sh
# Runs lightweight repository checks before commit.

set -eu

echo "Running diff hygiene check..."
git diff --cached --check

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

for FILE in $STAGED_FILES; do
    case "$FILE" in
        scripts/*.sh|scripts/*/*.sh|tools/git-hooks/*)
            if [ -f "$FILE" ]; then
                echo "Checking shell syntax: $FILE"
                sh -n "$FILE"
            fi
            ;;
    esac
done

if echo "$STAGED_FILES" | grep -q '^scripts/create-harness\.sh$'; then
    echo "Checking create-harness.sh syntax..."
    bash -n scripts/create-harness.sh
fi

echo "Pre-commit checks passed."
