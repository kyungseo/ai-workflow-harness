#!/usr/bin/env sh
# Runs lightweight repository checks before commit.

set -eu

ROOT=$(git rev-parse --show-toplevel)
GATE_LISTS="$ROOT/tools/git-hooks/lib/gate-lists.sh"
if [ ! -r "$GATE_LISTS" ]; then
    echo "ERROR: Missing git hook gate list SSoT: $GATE_LISTS"
    echo "Reinstall or restore tools/git-hooks/lib/gate-lists.sh."
    exit 1
fi
. "$GATE_LISTS"

echo "Running diff hygiene check..."
git diff --cached --check

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

is_source_gitflow() {
    grep -q "policy_type: source-gitflow" "$ROOT/docs/GIT-WORKFLOW.md" 2>/dev/null
}

FINALIZATION_ONLY=0
if is_source_gitflow; then
    FINALIZATION_COUNT=0
    SUBSTANTIVE_COUNT=0
    for FILE in $STAGED_FILES; do
        if awh_is_finalization_file "$FILE"; then
            FINALIZATION_COUNT=$((FINALIZATION_COUNT + 1))
        else
            SUBSTANTIVE_COUNT=$((SUBSTANTIVE_COUNT + 1))
        fi
    done
    if [ "$FINALIZATION_COUNT" -gt 0 ] && [ "$SUBSTANTIVE_COUNT" -eq 0 ]; then
        FINALIZATION_ONLY=1
    fi
fi

BRANCH=$(git branch --show-current 2>/dev/null || echo "")
# initial commit, merge commit (release sync 등) — branch isolation check 면제
if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    : # skip — initial commit, no HEAD yet
elif [ -f ".git/MERGE_HEAD" ]; then
    : # skip — merge commit
elif [ "$BRANCH" = "develop" ] || [ "$BRANCH" = "main" ]; then
    PROTECTED=""
    DEVELOP_T1_ONLY=1
    for FILE in $STAGED_FILES; do
        if awh_is_branch_isolation_protected_path "$FILE"; then
            PROTECTED="$PROTECTED $FILE"
        fi
        if [ "$BRANCH" = "develop" ] && ! awh_is_branch_isolation_tracking_path "$FILE"; then
            DEVELOP_T1_ONLY=0
        fi
    done
    if [ -n "$PROTECTED" ]; then
        if [ "$BRANCH" = "main" ]; then
            echo "ERROR: Committing protected workflow files directly on 'main' is not allowed."
            echo "Create a feature/* or hotfix/* branch and commit there instead."
            echo "Affected files:"
            for F in $PROTECTED; do echo "  $F"; done
            exit 1
        elif [ "$DEVELOP_T1_ONLY" -eq 1 ]; then
            echo "WARNING: Committing tracking-state workflow files directly on 'develop'."
            echo "This bounded exception applies only when the entire staged set is limited to docs/STATUS.md, docs/backlog/**, or docs/works/**."
            echo "Affected files:"
            for F in $PROTECTED; do echo "  $F"; done
        else
            echo "ERROR: Committing structural-policy or mixed protected workflow changes directly on 'develop' is not allowed."
            echo "Use a feature/* branch instead. The warning-only exception is limited to tracking-state-only staged sets."
            echo "Affected files:"
            for F in $PROTECTED; do echo "  $F"; done
            exit 1
        fi
    fi
fi

for FILE in $STAGED_FILES; do
    case "$FILE" in
        scripts/*.sh|scripts/*/*.sh|tools/git-hooks/*)
            if [ -f "$FILE" ]; then
                echo "Checking shell syntax: $FILE"
                sh -n "$FILE"
            fi
            ;;
    esac
done

if echo "$STAGED_FILES" | grep -q '^scripts/create-harness\.sh$'; then
    echo "Checking create-harness.sh syntax..."
    bash -n scripts/create-harness.sh
fi

# Shipped DR reference closure (DR-033) — source repo only.
# The check script ships in the source repo but not to scaffolded targets, so the
# existence guard makes this a no-op in adopter repos (the deployed hook stays inert).
CLOSURE_CHECK="$ROOT/scripts/tests/check-shipped-dr-closure.sh"
if [ -f "$CLOSURE_CHECK" ]; then
    echo "Checking shipped DR reference closure..."
    if ! CLOSURE_OUT=$(bash "$CLOSURE_CHECK" 2>&1); then
        echo "$CLOSURE_OUT"
        echo "ERROR: shipped 표면이 scaffold seed 밖 DR을 참조합니다 — commit 차단 (DR-033)."
        echo "mode-a(canonical self-describe) 또는 mode-b(DR 파일 Linked DRs frontmatter)로 처리 후 재시도하세요."
        exit 1
    fi
fi

# Source-parity checks (DR-040) — source repo only; existence-guarded no-op in adopters.
# Catches default-template / surface-mirror drift at commit time, before it enters history.
PARITY_DEFAULT="$ROOT/scripts/tests/check-default-template-parity.sh"
PARITY_MIRROR="$ROOT/scripts/tests/check-surface-mirror-parity.sh"
if [ -f "$PARITY_DEFAULT" ]; then
    echo "Checking default template parity..."
    if ! PARITY_OUT=$(bash "$PARITY_DEFAULT" 2>&1); then
        echo "$PARITY_OUT"
        echo "ERROR: default template parity drift — commit 차단 (DR-040)."
        exit 1
    fi
fi
if [ -f "$PARITY_MIRROR" ]; then
    echo "Checking surface mirror/prompt parity..."
    if ! PARITY_OUT=$(bash "$PARITY_MIRROR" 2>&1); then
        echo "$PARITY_OUT"
        echo "ERROR: surface mirror/prompt parity drift — commit 차단 (DR-040)."
        exit 1
    fi
fi

if [ "$FINALIZATION_ONLY" -eq 1 ]; then
    echo "WARNING: Staged changes look like a finalization-only commit."
    echo "DR-025 prefers bundling T15/T16 finalization with the substantive work commit."
    echo "The commit-msg hook will decide hard-stop/warning/report-only using git context and override trailers."
    echo "Override trailer when intentional:"
    echo "  $AWH_GATE_OVERRIDE_TRAILER: $AWH_GATE_OVERRIDE_TOKEN"
    echo "  $AWH_GATE_REASON_TRAILER: <one-line reason>"
fi

echo "Pre-commit checks passed."
