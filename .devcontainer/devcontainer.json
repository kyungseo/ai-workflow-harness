{
  "name": "base-msa-template",
  "dockerComposeFile": "docker-compose.devcontainer.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "humao.rest-client",
        "eamodio.gitlens",
        "gradle.vscode-gradle"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-21",
            "default": true
          }
        ],
        "editor.formatOnSave": true
      }
    }
  },
  "postCreateCommand": "./gradlew build -x test",
  "forwardPorts": [8090, 8091, 8092, 8093, 5432, 6379],
  "portsAttributes": {
    "8090": { "label": "API Gateway" },
    "8091": { "label": "Auth Service" },
    "8092": { "label": "User Service" },
    "8093": { "label": "Todo Service" },
    "5432": { "label": "PostgreSQL" },
    "6379": { "label": "Redis" }
  }
}
