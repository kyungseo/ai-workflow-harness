<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- #{} 파라미터 바인딩 사용. ${} 절대 사용 금지 (SQL Injection 방어) -->
<mapper namespace="io.kyungseo.msa.todo.mapper.UserExistenceMapper">

    <select id="existsById" resultType="boolean">
        SELECT EXISTS (
            SELECT 1 FROM users WHERE id = #{userId} AND enabled = TRUE
        )
    </select>

</mapper>
