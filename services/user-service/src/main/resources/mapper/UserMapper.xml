<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- #{} 파라미터 바인딩 사용. ${} 절대 사용 금지 (SQL Injection 방어) -->
<mapper namespace="io.kyungseo.msa.user.mapper.UserMapper">

    <resultMap id="userResultMap" type="io.kyungseo.msa.user.domain.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="role" column="role"/>
        <result property="enabled" column="enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="userResultMap">
        SELECT id, username, email, password, role, enabled, created_at, updated_at
        FROM users
        ORDER BY id
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM users
    </select>

    <select id="findById" parameterType="long" resultMap="userResultMap">
        SELECT id, username, email, password, role, enabled, created_at, updated_at
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail" parameterType="string" resultMap="userResultMap">
        SELECT id, username, email, password, role, enabled, created_at, updated_at
        FROM users
        WHERE email = #{email}
    </select>

    <select id="existsByEmail" parameterType="string" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM users WHERE email = #{email})
    </select>

    <insert id="insert" parameterType="io.kyungseo.msa.user.domain.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, email, password, role, enabled)
        VALUES (#{username}, #{email}, #{password}, #{role}, #{enabled})
    </insert>

    <update id="update" parameterType="io.kyungseo.msa.user.domain.User">
        UPDATE users
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM users WHERE id = #{id}
    </delete>

</mapper>
