# base-msa-template 환경변수 템플릿
# 이 파일을 복사하여 .env 를 생성하고 실제 값을 기입하세요.
# .env 는 .gitignore 에 포함되어 있으므로 절대 커밋하지 마세요.

SPRING_PROFILES_ACTIVE=local

# JWT 설정 (256-bit 이상 랜덤 문자열 필수)
JWT_SECRET=
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# DB 설정
DB_URL=jdbc:postgresql://localhost:5432/msa_db
DB_USERNAME=
DB_PASSWORD=
DB_NAME=msa_db
DB_POOL_MAX=10
DB_POOL_MIN=5
DB_CONN_TIMEOUT=30000

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS 허용 Origin
ALLOWED_ORIGINS=http://localhost:3000

# Gateway Blacklist 실패 정책 (fail-close: 보안 우선 / fail-open: 가용성 우선)
BLACKLIST_FAIL_POLICY=fail-close

# 서비스 URL (로컬 직접 실행 시)
AUTH_SERVICE_URL=http://localhost:8091
USER_SERVICE_URL=http://localhost:8092
TODO_SERVICE_URL=http://localhost:8093
