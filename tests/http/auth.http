### auth-service HTTP 테스트 (VS Code REST Client)
### 포트: 8091 (직접 호출), Gateway 경유 시 8090/api/v1/auth/...
### 계정: admin/admin, user/user, user2~4/user2~4 (02-data.sql 참조)

@baseUrl = http://localhost:8091
@contentType = application/json

### ─────────────────────────────────────────
### 1. 로그인 (Access + Refresh Token 발급)
### ─────────────────────────────────────────
# @name login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "username": "user",
  "password": "user",
  "deviceId": "my-device-001"
}

###

@accessToken = {{login.response.body.data.accessToken}}
@refreshToken = {{login.response.body.data.refreshToken}}

### ─────────────────────────────────────────
### 2. 토큰 갱신 (Refresh Token Rotation)
### ─────────────────────────────────────────
# @name refresh
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}",
  "deviceId": "my-device-001"
}

###

@newAccessToken = {{refresh.response.body.data.accessToken}}

### ─────────────────────────────────────────
### 3. 로그아웃 (Blacklist 등록 + RT 삭제)
### ─────────────────────────────────────────
POST {{baseUrl}}/api/v1/auth/logout
Content-Type: {{contentType}}
Authorization: Bearer {{newAccessToken}}

{
  "deviceId": "my-device-001"
}

### ─────────────────────────────────────────
### 4. 로그인 실패 — 잘못된 비밀번호 (AUTH-0001)
### ─────────────────────────────────────────
POST {{baseUrl}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "username": "user",
  "password": "wrongpassword",
  "deviceId": "my-device-001"
}

### ─────────────────────────────────────────
### 5. 로그인 실패 — 필수 필드 누락 (COMMON-0002)
### ─────────────────────────────────────────
POST {{baseUrl}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "username": "user"
}

### ─────────────────────────────────────────
### 6. admin 로그인
### ─────────────────────────────────────────
# @name adminLogin
POST {{baseUrl}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "admin",
  "deviceId": "admin-device"
}

###

@adminAccessToken = {{adminLogin.response.body.data.accessToken}}
