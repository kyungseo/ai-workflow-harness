<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<!--
    Checkstyle suppressions for base-msa-template.
    Add suppressions when a rule cannot be satisfied for a legitimate reason.
    Document the reason in a comment.
-->
<suppressions>
    <!-- Test files: relax naming and structural rules.
         Descriptive method names and BDD-style variable names are intentional. -->
    <suppress files=".*Test\.java" checks="MemberName|LocalVariableName|MethodName"/>

    <!-- Test files: MockMvc request/result builders and Mockito matchers are
         conventionally imported with star imports in Spring/Mockito test suites. -->
    <suppress files=".*Test\.java" checks="AvoidStarImport"/>

    <!-- Gradle-generated build directories: not source code -->
    <suppress files="[/\\]build[/\\]" checks=".*"/>
</suppressions>
